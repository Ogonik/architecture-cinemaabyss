Rel_D(user, front_web, "<<Uses>>", "")
Rel_D(user, front_android, "<<Uses>>", "")
Rel_D(user, front_ios, "<<Uses>>", "")
Rel_D(user, front_tv, "<<Uses>>", "")


BiRel_D(ca_bff_desktop, front_web, "Обмен данными")
BiRel_D(ca_bff_mobile, front_android, "Обмен данными", "")
BiRel_D(ca_bff_mobile, front_ios, "Обмен данными", "")
BiRel_D(ca_bff_tv, front_tv, "Обмен данными", "")


@enduml