{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss:fff zzz}] [{Level:u3}] [{SourceContext} {ClassName}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",

          "path": "./logs/log.txt",
          "rollingInterval": "Day",
          "shared": "true",
          "fileSizeLimitBytes": "1000000",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "jc_translation_service"
    }
  },

  "AllowedHosts": "*",
  "KafkaConsumerSettings": {
    "BootstrapServers": "",
    "ConsumerGroup": "1"
  },
  "KafkaProducerSettings": {
    "BootstrapServers": "",
    "MoviesTopicName": "movie-events",
    "UserTopicName": "user-events",
    "PaymentTopicName": "payment-events"
  }
}


